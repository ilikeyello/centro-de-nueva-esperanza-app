require_relative '../../../node_modules/.bun/@capacitor+ios@7.6.6+2d6e333445ff1eef/node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '14.0'
use_frameworks!

# workaround to avoid Xcode caching of Pods that requires
# Product -> Clean Build Folder after new Cordova plugins installed
# Requires CocoaPods 1.6 or newer
install! 'cocoapods', :disable_input_output_paths => true

def capacitor_pods
  pod 'Capacitor', :path => '../../../node_modules/.bun/@capacitor+ios@7.6.6+2d6e333445ff1eef/node_modules/@capacitor/ios'
  pod 'CapacitorCordova', :path => '../../../node_modules/.bun/@capacitor+ios@7.6.6+2d6e333445ff1eef/node_modules/@capacitor/ios'
  pod 'CapacitorApp', :path => '../../../node_modules/.bun/@capacitor+app@7.1.2+2d6e333445ff1eef/node_modules/@capacitor/app'
  pod 'CapacitorPushNotifications', :path => '../../../node_modules/.bun/@capacitor+push-notifications@7.0.6+2d6e333445ff1eef/node_modules/@capacitor/push-notifications'
  pod 'CapacitorSplashScreen', :path => '../../../node_modules/.bun/@capacitor+splash-screen@7.0.5+2d6e333445ff1eef/node_modules/@capacitor/splash-screen'
  pod 'CapacitorStatusBar', :path => '../../../node_modules/.bun/@capacitor+status-bar@7.0.6+2d6e333445ff1eef/node_modules/@capacitor/status-bar'
end

target 'App' do
  capacitor_pods
  # Add your Pods here
end

post_install do |installer|
  assertDeploymentTarget(installer)

  # Silence "[CP] Embed Pods Frameworks will be run during every build" warning
  # caused by `:disable_input_output_paths => true` above. Marking the script
  # phases as always-out-of-date matches the actual behavior and clears the warning.
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.native_targets.each do |native_target|
      native_target.build_phases.each do |phase|
        if phase.respond_to?(:name) && phase.name && phase.name.start_with?('[CP]')
          phase.always_out_of_date = "1"
        end
      end
    end
    aggregate_target.user_project.save
  end
end
